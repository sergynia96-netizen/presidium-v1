generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @default(uuid())
  name                 String
  email                String             @unique
  passwordHash         String?
  avatar               String             @default("")
  status               String             @default("offline")
  pinEnabled           Boolean            @default(false)
  pinHash              String?
  bio                  String?
  username             String?            @unique
  phone                String?
  birthday             String?
  emailVerified        DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  chatMembers          ChatMember[]
  settings             UserSettings?
  aiConversations      AIConversation[]
  accounts             Account[]
  sessions             Session[]
  contacts             Contact[]          @relation("UserOwnContacts")
  contactOf            Contact[]          @relation("UserContacts")
  sentMessages         Message[]          @relation("UserMessages")
  feedPosts            FeedPost[]
  feedComments         FeedComment[]
  feedReactions        FeedReaction[]
  stories              Story[]
  storyViews           StoryView[]
  storyRepliesSent     StoryReply[]       @relation("StoryReplyFrom")
  storyRepliesReceived StoryReply[]       @relation("StoryReplyTo")
  pushSubscriptions    PushSubscription[]
  bots                 Bot[]
  apiKeys              ApiKey[]
  webhooks             Webhook[]

  @@index([email])
  @@index([username])
  @@map("users")
}

model Bot {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  prompt      String
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([name])
  @@map("bots")
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  name        String
  key         String    @unique
  permissions String
  lastUsed    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(uuid())
  userId    String
  url       String
  events    String
  secret    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([enabled])
  @@map("webhooks")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ChatMember {
  id       String   @id @default(uuid())
  userId   String
  chatId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  chat     Chat     @relation(fields: [chatId], references: [id])

  @@index([userId])
  @@index([chatId])
  @@map("chat_members")
}

model Chat {
  id              String       @id @default(uuid())
  type            String       @default("private")
  name            String
  avatar          String       @default("")
  lastMessage     String       @default("")
  lastMessageTime String       @default("")
  unreadCount     Int          @default(0)
  isPinned        Boolean      @default(false)
  isMuted         Boolean      @default(false)
  isEncrypted     Boolean      @default(false)
  encryptionType  String?
  members         ChatMember[]
  messages        Message[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("chats")
}

model Message {
  id                      String   @id @default(uuid())
  chatId                  String
  senderId                String
  senderName              String   @default("")
  senderAvatar            String   @default("")
  content                 String
  type                    String   @default("text")
  status                  String   @default("sent")
  isMe                    Boolean  @default(false)
  mediaUrl                String?
  mediaType               String?
  mediaName               String?
  mediaSize               Int?
  mediaMimeType           String?
  isPinned                Boolean  @default(false)
  isEdited                Boolean  @default(false)
  replyToMessageId        String?
  replyToSenderName       String?
  replyToContent          String?
  replyToType             String?
  forwardedFromMessageId  String?
  forwardedFromSenderName String?
  forwardedFromContent    String?
  forwardedFromType       String?
  forwardedFromChatName   String?
  chat                    Chat     @relation(fields: [chatId], references: [id])
  sender                  User     @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([chatId])
  @@index([senderId])
  @@map("messages")
}

model UserSettings {
  id                  String  @id @default(uuid())
  userId              String  @unique
  desktopNotif        Boolean @default(true)
  taskbarAnim         Boolean @default(false)
  notifPrivate        Boolean @default(true)
  notifChannels       Boolean @default(true)
  notifGroups         Boolean @default(false)
  notifNewUser        Boolean @default(false)
  notifPinned         Boolean @default(false)
  notifCalls          Boolean @default(true)
  notifPreview        Boolean @default(true)
  notifVibration      Boolean @default(true)
  notifMutedAll       Boolean @default(false)
  sound               Boolean @default(true)
  autoDelete          String  @default("Off")
  readReceipts        Boolean @default(true)
  typingIndicators    Boolean @default(true)
  onlineStatus        Boolean @default(true)
  privacyLastSeen     String  @default("contacts")
  privacyProfilePhoto String  @default("contacts")
  privacyAbout        String  @default("everyone")
  privacyGroupAdds    String  @default("contacts")
  privacyCallFrom     String  @default("everyone")
  openClawEnabled     Boolean @default(true)
  locale              String  @default("en")
  accentColor         String  @default("emerald")
  twoFactorEnabled    Boolean @default(false)
  twoFactorSecret     String?
  user                User    @relation(fields: [userId], references: [id])

  @@map("user_settings")
}

model Contact {
  id         String   @id @default(uuid())
  userId     String
  contactId  String
  name       String?
  isFavorite Boolean  @default(false)
  isBlocked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation("UserOwnContacts", fields: [userId], references: [id], onDelete: Cascade)
  contact    User     @relation("UserContacts", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
  @@index([userId])
  @@index([contactId])
  @@map("contacts")
}

model AIConversation {
  id          String                  @id @default(uuid())
  userId      String
  title       String
  mode        String                  @default("default")
  lastMessage String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    AIConversationMessage[]

  @@index([userId])
  @@index([mode])
  @@map("ai_conversations")
}

model AIConversationMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String
  content        String
  timestamp      String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([timestamp])
  @@map("ai_conversation_messages")
}

model FeedPost {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  content     String
  likes       Int      @default(0)
  dislikes    Int      @default(0)
  comments    Int      @default(0)
  repostCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  commentsList FeedComment[]
  reactions    FeedReaction[]

  @@index([authorId, createdAt])
  @@index([createdAt])
  @@map("feed_posts")
}

model FeedComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
  @@map("feed_comments")
}

model FeedReaction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  type      String
  createdAt DateTime @default(now())

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId, type])
  @@index([userId, createdAt])
  @@map("feed_reactions")
}

model Story {
  id             String    @id @default(uuid())
  sourceId       String
  sourceType     String
  creatorId      String
  creatorName    String
  creatorAvatar  String?
  type           String
  content        String
  mediaUrl       String?
  mediaMimeType  String?
  mediaName      String?
  mediaSize      Int?
  e2eKey         String?
  e2eIv          String?
  e2eTag         String?
  thumbnail      String?
  privacy        String
  allowedUserIds String?
  views          Int       @default(0)
  replyCount     Int       @default(0)
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  deletedAt      DateTime?

  creator     User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  viewEntries StoryView[]
  replies     StoryReply[]

  @@index([sourceType, sourceId, createdAt])
  @@index([creatorId, createdAt])
  @@index([expiresAt])
  @@map("stories")
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  userId   String
  viewedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([userId, viewedAt])
  @@map("story_views")
}

model StoryReply {
  id         String   @id @default(uuid())
  storyId    String
  fromUserId String
  toUserId   String
  content    String
  messageId  String?
  createdAt  DateTime @default(now())

  story    Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  fromUser User  @relation("StoryReplyFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User  @relation("StoryReplyTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt])
  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
  @@map("story_replies")
}

model PushSubscription {
  id             String   @id @default(uuid())
  userId         String
  endpoint       String   @unique
  p256dh         String
  auth           String
  expirationTime String?
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("push_subscriptions")
}
