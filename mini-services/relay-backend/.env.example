PORT=3001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=change-me-in-production
RELAY_DATABASE_URL=file:./presidium.db
# Security: keep false by default. When true (and NODE_ENV != production),
# auth endpoints may include devOtpPreview in responses for local testing.
RELAY_DEV_OTP_PREVIEW=false
