# ===========================================
# PRESIDIUM - Production Environment Variables
# ===========================================
# Copy this file to .env.production and configure for your deployment
# NEVER commit actual values to version control!

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
DATABASE_URL="postgresql://presidium:changeme_production_password@db:5432/presidium?schema=public"

# ===========================================
# Authentication (NextAuth.js)
# ===========================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-with-openssl-rand-base64-32"

# ===========================================
# AI Provider Configuration
# ===========================================
GLM4_API_KEY="your-glm4-api-key-here"
AI_PROVIDER="glm4"

# ===========================================
# Relay Backend Configuration
# ===========================================
NEXT_PUBLIC_RELAY_HTTP_URL="http://localhost:3001"
NEXT_PUBLIC_RELAY_WS_URL="ws://localhost:3001/ws"
JWT_SECRET="your-relay-jwt-secret-here"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ===========================================
# Redis (for distributed relay sessions)
# ===========================================
REDIS_URL="redis://redis:6379"
REDIS_CLUSTER_NODES=""
RELAY_NODE_ID=""
RELAY_SESSION_TTL_MS="120000"

# ===========================================
# Application Settings
# ===========================================
NODE_ENV="production"
PORT="3000"
HOSTNAME="0.0.0.0"

# ===========================================
# Security
# ===========================================
# Generate with: openssl rand -base64 32
TWO_FACTOR_SECRET=""
TWO_FACTOR_ISSUER="PRESIDIUM"

# ===========================================
# Optional Features
# ===========================================
OPENCLAW_ENABLED="true"
DEV_OTP_PREVIEW="false"
DEV_PASSWORD_RESET_PREVIEW="false"

# ===========================================
# Tenor API (for GIF search)
# ===========================================
TENOR_API_KEY=""
