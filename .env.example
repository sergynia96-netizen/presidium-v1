# ===========================================
# PRESIDIUM MESSENGER — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control

# ===========================================
# AI Provider Configuration
# ===========================================

# GLM-4 API (Free tier from Zhipu AI)
# Get your API key: https://open.bigmodel.cn/usercenter/apikeys
GLM4_API_KEY="your-glm4-api-key-here"

# AI Provider selection: 'glm4' (default) or 'zai' (fallback)
AI_PROVIDER="glm4"

# Default GLM model identifier
GLM4_MODEL="glm-4.7-flash"

# Tenor API key for real GIF search in chat picker
# Get key: https://developers.google.com/tenor/guides/quickstart
TENOR_API_KEY=""

# ===========================================
# Database Configuration
# ===========================================

# SQLite (development)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production - recommended)
# DATABASE_URL="postgresql://user:password@localhost:5432/presidium?schema=public"

# Docker compose secrets (required for secure startup)
DB_PASSWORD="your-postgres-password"
REDIS_PASSWORD="your-redis-password"

# ===========================================
# Authentication (NextAuth.js)
# ===========================================

# NextAuth URL (change in production)
NEXTAUTH_URL="http://localhost:3000"

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# OAuth Providers (optional)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-secret"
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-secret"

# ===========================================
# Relay Backend (mini-services/relay-backend)
# ===========================================

# HTTP base URL for relay backend API
NEXT_PUBLIC_RELAY_HTTP_URL="http://localhost:3001"

# WebSocket URL for relay signaling
NEXT_PUBLIC_RELAY_WS_URL="ws://localhost:3001/ws"

# JWT secret for relay backend
# You can reuse NEXTAUTH_SECRET in local dev
JWT_SECRET="your-relay-jwt-secret-here"

# Allowed browser origins for relay backend CORS
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Redis (required for distributed relay sessions + offline queue in multi-node setup)
# Standalone Redis:
REDIS_URL=""
# Cluster mode (comma-separated host:port list). If set, has priority over REDIS_URL.
REDIS_CLUSTER_NODES=""
# Optional relay node id (helps with diagnostics in multi-node deployments)
RELAY_NODE_ID=""
# Session TTL in Redis presence store (milliseconds)
RELAY_SESSION_TTL_MS="120000"

# ===========================================
# Rate Limiting (Production)
# ===========================================

# Upstash Redis (for rate limiting in production)
# Get from: https://console.upstash.com/
# KV_REST_API_URL="https://your-redis-url.upstash.io"
# KV_REST_API_TOKEN="your-redis-token"

# ===========================================
# Application Settings
# ===========================================

# Node environment
NODE_ENV="development"

# Application port
PORT="3000"

# ===========================================
# Optional Features
# ===========================================

# Enable/disable OpenClaw moderation
OPENCLAW_ENABLED="true"

# Allow AI chat usage without authenticated NextAuth session.
# Recommended only for local development/testing.
ALLOW_ANON_AI="true"

# Client-side storage quota (shown in profile storage manager)
NEXT_PUBLIC_STORAGE_QUOTA_MB="1024"

# Development-only OTP preview in API responses (set to "false" to hide preview)
DEV_OTP_PREVIEW="true"

# Development-only password reset preview (set to "false" to hide preview link)
DEV_PASSWORD_RESET_PREVIEW="true"

# Optional dedicated encryption key for 2FA secrets at rest
# If empty, NEXTAUTH_SECRET is used as fallback
TWO_FACTOR_SECRET_KEY=""

# Label shown in authenticator apps
TWO_FACTOR_ISSUER="PRESIDIUM"

# Analytics (Plausible - privacy-friendly)
# PLAUSIBLE_DOMAIN="your-domain.com"
# PLAUSIBLE_HOST="https://plausible.io"

# Email (for notifications)
# SMTP_HOST="smtp.mail.ru"
# SMTP_PORT="465"
# SMTP_USER="presidium_messenger@internet.ru"
# SMTP_PASS="your-smtp-app-password"
# SMTP_SECURE="true"
# Set to "false" only for local debug behind strict VPN/proxy with TLS interception
# SMTP_TLS_REJECT_UNAUTHORIZED="true"
# Optional sender address (defaults to SMTP_USER)
# SMTP_FROM="presidium_messenger@internet.ru"

# Web Push (VAPID)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Optional S3/MinIO settings (for media storage if enabled)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_BUCKET="presidium"

# MinIO root credentials (if using local MinIO container)
MINIO_ROOT_USER="your-minio-root-user"
MINIO_ROOT_PASSWORD="your-minio-root-password"
